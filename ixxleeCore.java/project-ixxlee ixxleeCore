 package com.ixxlee.core.native

import java.io.File
import kotlin.io.path.createTempFile

object NativeLoader {

    fun loadFlipper() {
        val os = System.getProperty("os.name").lowercase()
        val arch = System.getProperty("os.arch").lowercase()

        val resourcePath = when {
            os.contains("win") && arch.contains("64") ->
                "/native/windows/flipper.dll"

            os.contains("win") && arch.contains("arm") ->
                "/native/windows-arm64/flipper.dll"

            os.contains("mac") && arch.contains("aarch64") ->
                "/native/macos-arm64/libflipper.dylib"

            os.contains("mac") ->
                "/native/macos/libflipper.dylib"

            os.contains("linux") && arch.contains("aarch64") ->
                "/native/linux-arm64/libflipper.so"

            os.contains("linux") ->
                "/native/linux-x86_64/libflipper.so"

            else -> error("Unsupported OS/architecture for libflipper")
        }

        val tempFile = createTempFile("libflipper", null).toFile()
        tempFile.deleteOnExit()

        NativeLoader::class.java.getResourceAsStream(resourcePath)?.use { input ->
            tempFile.outputStream().use { output ->
                input.copyTo(output)
            }
        } ?: error("Failed to load resource: $resourcePath")

        System.load(tempFile.absolutePath)
    }
}fun main() {
    NativeLoader.loadFlipper()
    // then start orchestrator, plugins, etc.
}
