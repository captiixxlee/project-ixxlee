    private val mutex = Mutex()
    private val records = mutableMapOf<String, MemoryRecord>()

    override suspend fun write(key: String, value: String, tags: List<String>) {
        mutex.withLock {
            records[key] = MemoryRecord(
                key = key,
                value = value,
                tags = tags,
                timestamp = System.currentTimeMillis()
            )
        }
    }

