import com.ixxlee.core.VectorMemory
import com.ixxlee.core.VectorResult
import kotlin.math.sqrt

class SimpleVectorMemory : VectorMemory {

    private val embeddings = mutableMapOf<String, FloatArray>()

    override suspend fun embed(text: String): FloatArray {
        // toy embedding: hash‑based
        val bytes = text.toByteArray()
        val vec = FloatArray(16)
        bytes.forEachIndexed { i, b ->
            vec[i % vec.size] += (b.toInt() and 0xFF) / 255f
        }
        return vec
    }

    override suspend fun search(query: String, limit: Int): List<VectorResult> {
        val q = embed(query)
        return embeddings.map { (key, vec) ->
            VectorResult(key, cosine(q, vec))
        }.sortedByDescending { it.score }
            .take(limit)
    }

    fun store(key: String, text: String) {
        // non‑suspend helper
        // in real use, call from a coroutine
        // and persist alongside MemoryStore
        // for now, just in‑memory
        // (you can wire this to MemoryWrite later)
        kotlinx.coroutines.runBlocking {
            embeddings[key] = embed(text)
        }
    }

    private fun cosine(a: FloatArray, b: FloatArray): Float {
        val dot = a.indices.sumOf { (a[it] * b.getOrElse(it) { 0f }).toDouble() }.toFloat()
        val na = sqrt(a.sumOf { (it * it).toDouble() }.toFloat())
        val nb = sqrt(b.sumOf { (it * it).toDouble() }.toFloat())
        return if (na == 0f || nb == 0f) 0f else dot / (na * nb)
    }
}

